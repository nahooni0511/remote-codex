{
  "name": "remote-codex",
  "private": true,
  "version": "0.1.0",
  "description": "Monorepo for Remote Codex web and API server.",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c green,cyan \"npm run dev -w @remote-codex/api-server\" \"npm run dev -w @remote-codex/web\"",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "e2e": "playwright test",
    "e2e:realdata": "playwright test -c playwright.realdata.config.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "concurrently": "^9.2.1"
  }
}
